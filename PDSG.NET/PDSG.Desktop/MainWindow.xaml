<Window x:Class="PDSG.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PDSG 配电柜系统图自动生成工具 v2.0 (.NET)" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen" MinHeight="500" MinWidth="800">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部: 文件选择 -->
        <GroupBox Grid.Row="0" Header="文件选择" Padding="6" Margin="0,0,0,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Excel:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,4,0"/>
                <TextBox Grid.Column="1" x:Name="txtExcelPath" Margin="0,0,4,0" VerticalContentAlignment="Center"/>
                <Button Grid.Column="2" Content="浏览..." Width="65" Click="BtnBrowseExcel_Click" Margin="0,0,8,0"/>

                <TextBlock Grid.Column="3" Text="输出:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,4,0"/>
                <TextBox Grid.Column="4" x:Name="txtOutputPath" Width="200" Margin="0,0,4,0" VerticalContentAlignment="Center"/>
                <Button Grid.Column="5" Content="浏览..." Width="65" Click="BtnBrowseOutput_Click"/>
            </Grid>
        </GroupBox>

        <!-- 中部: 标签页 -->
        <TabControl Grid.Row="1" x:Name="tabMain" Margin="0,0,0,4">
            <!-- 配置标签页 -->
            <TabItem Header="  配置  ">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
                    <StackPanel>
                        <GroupBox Header="Excel 读取" Margin="4">
                            <StackPanel Margin="8">
                                <CheckBox x:Name="chkAutoDetect" Content="自动检测 Excel 格式（标准/转置）" IsChecked="True" Margin="0,0,0,4"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Sheet 名称:" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" x:Name="txtSheetName" Text="低压配电系统" Margin="4,0"/>
                                    <TextBlock Grid.Column="3" Text="默认断路器:" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                    <TextBox Grid.Column="4" x:Name="txtDefaultBreaker" Text="NSX100N" Margin="4,0"/>
                                </Grid>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="图块库" Margin="4">
                            <StackPanel Margin="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="图块库 DWG:" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" x:Name="txtBlockLibPath" Text="./blocks/block_library.dwg" Margin="4,0"/>
                                    <Button Grid.Column="2" Content="..." Width="30" Click="BtnBrowseBlockLib_Click"/>
                                </Grid>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="图块目录 YAML:" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" x:Name="txtBlockCatalogPath" Text="./blocks/block_catalog.yaml" Margin="4,0"/>
                                    <Button Grid.Column="2" Content="..." Width="30" Click="BtnBrowseBlockCatalog_Click"/>
                                </Grid>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="200"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="默认图块:" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" x:Name="txtDefaultBlock" Text="LOOP_POWER_A" Margin="4,0"/>
                                </Grid>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="布局参数" Margin="4">
                            <StackPanel Margin="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="回路间距 (mm):"/>
                                        <TextBox x:Name="txtSpacing" Text="70" Margin="0,2,8,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="母线 X 坐标:"/>
                                        <TextBox x:Name="txtBusX" Text="30" Margin="0,2,8,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="母线 Y 坐标:"/>
                                        <TextBox x:Name="txtBusY" Text="200" Margin="0,2,8,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3">
                                        <TextBlock Text="图纸幅面:"/>
                                        <ComboBox x:Name="cmbPaper" Margin="0,2,0,0">
                                            <ComboBoxItem Content="自动选择" IsSelected="True"/>
                                            <ComboBoxItem Content="A1"/>
                                            <ComboBoxItem Content="A2"/>
                                            <ComboBoxItem Content="A3"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 数据预览标签页 -->
            <TabItem Header="  数据预览  ">
                <Grid Margin="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                        <Button Content="加载预览" Click="BtnLoadPreview_Click" Padding="12,4" Margin="0,0,8,0"/>
                        <TextBlock x:Name="txtPreviewInfo" Text="请先选择 Excel 文件" VerticalAlignment="Center" Foreground="Gray"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" x:Name="dgPreview" AutoGenerateColumns="True" IsReadOnly="True"
                              AlternatingRowBackground="#F5F5F5" GridLinesVisibility="All" HeadersVisibility="Column"/>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock x:Name="txtRecordCount" Text="记录数: 0" VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <TextBlock x:Name="txtErrorCount" Text="错误数: 0" VerticalAlignment="Center" Foreground="#E74C3C"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- 执行标签页 -->
            <TabItem Header="  执行  ">
                <Grid Margin="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button x:Name="btnDryRun" Content="校验预览 (Dry-Run)" Click="BtnDryRun_Click"
                                Padding="16,6" FontWeight="Bold" Background="#3498DB" Foreground="White" Margin="0,0,8,0"/>
                        <Button x:Name="btnGenerate" Content="生成 DWG" Click="BtnGenerate_Click"
                                Padding="16,6" FontWeight="Bold" Background="#27AE60" Foreground="White" Margin="0,0,8,0"/>
                        <Button x:Name="btnStop" Content="停止" Click="BtnStop_Click"
                                Padding="16,6" IsEnabled="False" Margin="0,0,16,0"/>
                        <TextBlock x:Name="txtStatus" Text="就绪" VerticalAlignment="Center" FontSize="14" FontWeight="Bold"/>
                    </StackPanel>

                    <TextBox Grid.Row="1" x:Name="txtLog" IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12"
                             TextWrapping="Wrap" Background="#1E1E1E" Foreground="#D4D4D4" Padding="8"/>
                </Grid>
            </TabItem>

            <!-- 图块管理标签页 -->
            <TabItem Header="  图块管理  ">
                <Grid Margin="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 操作按钮 -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="加载目录" Click="BtnLoadCatalog_Click" Padding="12,4" Margin="0,0,4,0"/>
                        <Button Content="刷新图形块" Click="BtnRefreshBlocks_Click" Padding="12,4" Margin="0,0,4,0"/>
                        <Button Content="复核一致性" Click="BtnValidateBlocks_Click" Padding="12,4" Margin="0,0,8,0" Background="#3498DB" Foreground="White"/>
                        <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="0,0,8,0"/>
                        <Button Content="新建图块" Click="BtnCreateBlock_Click" Padding="12,4" Margin="0,0,4,0" Background="#27AE60" Foreground="White"/>
                        <Button Content="批量导入DWG" Click="BtnImportDwg_Click" Padding="12,4" Margin="0,0,4,0"/>
                        <Button Content="保存目录" Click="BtnSaveCatalog_Click" Padding="12,4" Margin="0,0,8,0"/>
                    </StackPanel>

                    <!-- 图块列表 -->
                    <DataGrid Grid.Row="1" x:Name="dgBlocks" AutoGenerateColumns="False" IsReadOnly="True"
                              AlternatingRowBackground="#F5F5F5" GridLinesVisibility="All" HeadersVisibility="Column"
                              SelectionMode="Single" SelectionChanged="DgBlocks_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="图块名称" Binding="{Binding Name}" Width="180"/>
                            <DataGridTextColumn Header="描述" Binding="{Binding Description}" Width="*"/>
                            <DataGridTextColumn Header="属性数" Binding="{Binding Attributes.Count}" Width="60"/>
                            <DataGridTextColumn Header="图形中存在" Binding="{Binding ExistsInDrawing, Converter={StaticResource BoolConverter}}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- 状态栏 -->
                    <Grid Grid.Row="2" Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" x:Name="txtBlockStatus" Text="请先加载图块目录" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" x:Name="txtBlockCount" Text="" VerticalAlignment="Center"/>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- 底部: 状态栏 -->
        <Border Grid.Row="2" Background="#F0F0F0" Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="txtStatusBar" Text="就绪"/>
                <TextBlock Grid.Column="1" x:Name="txtTime" Text=""/>
            </Grid>
        </Border>
    </Grid>
</Window>
